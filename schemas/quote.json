{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dmc12.ai/schemas/quote.json",
  "title": "DMC-12 Quote Capability v0.1.0",
  "description": "Input/output schema for ai.dmc12.automotive.quote (request_quote).",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": ["vin"],
      "properties": {
        "vin": {
          "type": "string",
          "pattern": "^[A-HJ-NPR-Z0-9]{17}$",
          "description": "17-character VIN; letters I, O, Q excluded."
        },
        "buyer_ref": {
          "type": ["string", "null"],
          "maxLength": 200,
          "description": "Opaque agent-side reference. MUST NOT contain PII."
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "required": ["quote_id", "vin", "quoted_price", "currency", "created_at", "expires_at"],
      "properties": {
        "quote_id": {"type": "string"},
        "vin": {"type": "string", "pattern": "^[A-HJ-NPR-Z0-9]{17}$"},
        "quoted_price": {
          "type": "number",
          "minimum": 0,
          "description": "Always equal to the merchant's listed asking_price at quote creation time. No negotiation."
        },
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
        "created_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"},
        "terms": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "required": ["input", "output"],
  "examples": [
    {
      "input": {
        "vin": "JF2GTHMC4P8123456",
        "buyer_ref": "session-7b3f2c"
      },
      "output": {
        "quote_id": "c2f1e0f4-4f9a-4b9e-9d7a-8c2d0f1a2b34",
        "vin": "JF2GTHMC4P8123456",
        "quoted_price": 33985.00,
        "currency": "USD",
        "created_at": "2026-04-21T18:00:00Z",
        "expires_at": "2026-04-21T18:30:00Z",
        "terms": "Price valid for 30 minutes. No negotiation. See dealer for out-the-door pricing."
      }
    }
  ]
}
