{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id":     "https://dmc12.ai/schemas/acceptance.json",
  "title":   "DMC-12 Offer Acceptance v0.1.0",
  "type":    "object",
  "additionalProperties": false,
  "required": ["offer_id", "context_id",
               "customer_consent", "accepted_at"],
  "properties": {
    "offer_id":         {"type": "string", "format": "uuid"},
    "context_id":       {"type": "string", "format": "uuid"},
    "customer_consent": {
      "const": true,
      "description": "MUST be true. Schema rejects false."
    },
    "accepted_at":      {"type": "string", "format": "date-time"}
  }
}
