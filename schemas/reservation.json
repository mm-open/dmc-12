{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dmc12.ai/schemas/reservation.json",
  "title": "DMC-12 Reservation Capability v0.1.0",
  "description": "Input/output schema for ai.dmc12.automotive.reservation (create/release/get_status).",
  "type": "object",
  "properties": {
    "input": {
      "oneOf": [
        {
          "title": "create_reservation",
          "type": "object",
          "required": ["quote_id"],
          "properties": {
            "quote_id": {
              "type": "string",
              "minLength": 10,
              "maxLength": 64
            },
            "customer_ref": {
              "type": ["string", "null"],
              "maxLength": 200,
              "description": "Opaque agent-side reference. MUST NOT contain PII."
            }
          },
          "additionalProperties": false
        },
        {
          "title": "release_reservation | get_reservation_status",
          "type": "object",
          "required": ["reservation_token"],
          "properties": {
            "reservation_token": {
              "type": "string",
              "minLength": 10,
              "maxLength": 80
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "output": {
      "type": "object",
      "required": ["reservation_token", "vin", "reserved_price", "created_at", "expires_at", "status"],
      "properties": {
        "reservation_token": {"type": "string"},
        "vin": {"type": "string", "pattern": "^[A-HJ-NPR-Z0-9]{17}$"},
        "reserved_price": {"type": "number", "minimum": 0},
        "created_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"},
        "released_at": {"type": ["string", "null"], "format": "date-time"},
        "released_by": {"type": ["string", "null"]},
        "status": {"enum": ["active", "released", "expired", "converted"]},
        "terms": {"type": "string"}
      }
    }
  },
  "required": ["input", "output"],
  "examples": [
    {
      "input": {
        "quote_id": "c2f1e0f4-4f9a-4b9e-9d7a-8c2d0f1a2b34",
        "customer_ref": "session-7b3f2c"
      },
      "output": {
        "reservation_token": "rsv_01HZ9QK7M3V8P2S6T4W0Y1Z3X5",
        "vin": "JF2GTHMC4P8123456",
        "reserved_price": 33985.00,
        "created_at": "2026-04-21T18:05:00Z",
        "expires_at": "2026-04-21T18:35:00Z",
        "released_at": null,
        "released_by": null,
        "status": "active",
        "terms": "30-minute soft hold. Not a binding purchase commitment."
      }
    }
  ]
}
